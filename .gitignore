# =============================================================================
# Heimdall - Git Ignore
# =============================================================================

# Terraform
.terraform/
*.tfstate
*.tfstate.*
*.tfvars
!*.tfvars.example
.terraform.lock.hcl
crash.log
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ansible
*.retry
ansible/inventory/production.yml  # Auto-generated by Terraform

# Secrets
.env
!.env.example
*.pem
*.key
secrets/

# Docker
docker/monitoring/prometheus_data/
docker/monitoring/grafana_data/
docker/monitoring/loki_data/
docker/monitoring/alertmanager_data/

# System
.DS_Store
*.log
*.swp
*.swo
*~

# IDE
.idea/
.vscode/
*.code-workspace

# Temporary
tmp/
temp/
*.tmp