      "pluginVersion": "10.4.1",
      "targets": [{ "expr": "(1 - (node_filesystem_avail_bytes{fstype!~\"tmpfs|overlay\",mountpoint=\"/\"} / node_filesystem_size_bytes{fstype!~\"tmpfs|overlay\",mountpoint=\"/\"})) * 100", "legendFormat": "{{ instance }}", "refId": "A" }],
      "title": "Disk Usage (Root Filesystem)",
