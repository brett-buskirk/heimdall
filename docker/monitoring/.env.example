# =============================================================================
# RCJ Monitoring Stack - Environment Variables
# =============================================================================
# Copy this file to .env and update with your values
# NEVER commit the actual .env file to version control!
# =============================================================================

# -----------------------------------------------------------------------------
# Grafana Configuration
# -----------------------------------------------------------------------------
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=your_secure_password_here

# Root URL for Grafana (used in links/redirects)
# For Tailscale: http://your-tailscale-hostname:3000
# For public: https://grafana.rcjourney.cloud
GRAFANA_ROOT_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# SMTP Configuration (for email alerts)
# -----------------------------------------------------------------------------
# Set to 'true' to enable email alerts
SMTP_ENABLED=false

# Your SMTP provider settings (examples for common providers below)
# Mailgun: smtp.mailgun.org:587
# SendGrid: smtp.sendgrid.net:587
# Gmail: smtp.gmail.com:587 (requires app password)
SMTP_HOST=smtp.mailgun.org:587
SMTP_USER=your_smtp_username
SMTP_PASSWORD=your_smtp_password
SMTP_FROM=alerts@rcjourney.cloud

# -----------------------------------------------------------------------------
# Spaces Configuration (for log archival)
# -----------------------------------------------------------------------------
# Used by Loki for long-term log storage (optional)
SPACES_ACCESS_KEY=your_spaces_access_key
SPACES_SECRET_KEY=your_spaces_secret_key
SPACES_BUCKET=rcj-logs-nyc3
SPACES_REGION=nyc3
