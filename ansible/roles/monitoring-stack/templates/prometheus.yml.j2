# Ansible Managed - Do not edit directly
global:
  scrape_interval: 15s
  evaluation_interval: 15s
  external_labels:
    environment: {{ environment | default('production') }}
    vpc: rcj-vpc-nyc3

alerting:
  alertmanagers:
    - static_configs:
        - targets:
            - alertmanager:9093

rule_files:
  - /etc/prometheus/alerts.yml

scrape_configs:
  - job_name: 'prometheus'
    static_configs:
      - targets: ['localhost:9090']
        labels:
          instance: 'rcj-management'

  - job_name: 'node-exporter-management'
    static_configs:
      - targets: ['node-exporter:9100']
        labels:
          instance: 'rcj-management'
          role: 'management'

  - job_name: 'node-exporter-apps'
    static_configs:
{% for host in groups['application_servers'] | default([]) %}
      - targets: ['{{ hostvars[host].private_ip }}:9100']
        labels:
          instance: '{{ host }}'
          role: 'application'
{% endfor %}
      # Manual entries (update after agent deployment)
      - targets: ['10.108.0.2:9100']
        labels:
          instance: 'rc-journey-wp'
          role: 'webserver'
          app: 'wordpress'
      - targets: ['10.108.0.3:9100']
        labels:
          instance: 'foundry-vtt'
          role: 'gameserver'
          app: 'foundry'

  - job_name: 'loki'
    static_configs:
      - targets: ['loki:3100']

  - job_name: 'grafana'
    static_configs:
      - targets: ['grafana:3000']

  - job_name: 'alertmanager'
    static_configs:
      - targets: ['alertmanager:9093']
