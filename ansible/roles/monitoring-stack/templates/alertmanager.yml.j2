# Ansible Managed - Do not edit directly
global:
  resolve_timeout: 5m
{% if smtp_host is defined and smtp_host %}
  smtp_smarthost: '{{ smtp_host }}'
  smtp_from: '{{ alert_email | default("alerts@yourdomain.com") }}'
  smtp_auth_username: '{{ smtp_user | default("") }}'
  smtp_auth_password: '{{ smtp_password | default("") }}'
  smtp_require_tls: true
{% endif %}

route:
  receiver: 'email-alerts'
  group_by: ['alertname', 'instance', 'severity']
  group_wait: 30s
  group_interval: 5m
  repeat_interval: 4h
  routes:
    - match:
        severity: critical
      receiver: 'email-critical'
      group_wait: 10s
      repeat_interval: 1h

# Email receivers only render their email_configs when SMTP is configured.
# Alertmanager refuses to start ("no global SMTP smarthost set") if a receiver
# has email_configs but no smarthost, so without smtp_host these stay as bare
# (inert) receivers — valid config that runs — and email activates once SMTP set.
receivers:
  - name: 'email-alerts'
{% if smtp_host is defined and smtp_host %}
    email_configs:
      - to: '{{ alert_email | default("alerts@yourdomain.com") }}'
        send_resolved: true
        headers:
          Subject: '[{{ project_name | upper }}] {% raw %}{{ .Status | toUpper }}: {{ .CommonLabels.alertname }}{% endraw %}'
{% endif %}

  - name: 'email-critical'
{% if smtp_host is defined and smtp_host %}
    email_configs:
      - to: '{{ alert_email | default("alerts@yourdomain.com") }}'
        send_resolved: true
        headers:
          Subject: '🚨 [CRITICAL] {% raw %}{{ .CommonLabels.alertname }} on {{ .CommonLabels.instance }}{% endraw %}'
{% endif %}

inhibit_rules:
  - source_match:
      severity: 'critical'
    target_match:
      severity: 'warning'
    equal: ['alertname', 'instance']
