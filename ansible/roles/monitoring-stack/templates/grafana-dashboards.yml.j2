# =============================================================================
# Grafana Dashboard Provisioning (Ansible Managed)
# =============================================================================
# Auto-loads dashboards from the dashboards folder on startup.
# =============================================================================

apiVersion: 1

providers:
  - name: '{{ project_name }} Infrastructure'
    orgId: 1
    folder: '{{ project_name }} Infrastructure'
    folderUid: '{{ project_name }}-infra'
    type: file
    disableDeletion: false
    updateIntervalSeconds: 30
    allowUiUpdates: true
    options:
      path: /etc/grafana/provisioning/dashboards
